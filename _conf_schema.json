    "common_config": {
        "description": "常规配置",
        "type": "object",
        "items": {
            "default_size": {
                "description": "默认图像尺寸",
                "type": "string",
                "default": "1024x1024",
                "options": ["512x512", "1024x1024", "1792x1024", "1024x1792", "2048x2048"]
            },
            "default_quality": {
                "description": "默认图像质量",
                "type": "string",
                "default": "standard",
                "options": ["standard", "hd", "ultra", "premium"]
            },
            "default_style": {
                "description": "默认图像风格",
                "type": "string",
                "default": "vivid",
                "options": ["vivid", "natural", "realistic", "anime", "illustration"]
            },
            "max_concurrent_jobs": {
                "description": "最大并发任务数",
                "type": "int",
                "default": 5
            },
            "enable_nsfw_filter": {
                "description": "启用NSFW过滤",
                "type": "bool",
                "default": true
            },
            "auto_save_images": {
                "description": "自动保存图像",
                "type": "bool",
                "default": true
            },
            "max_retry": {
                "description": "最大重试次数",
                "type": "int",
                "default": 3
            },
            "timeout": {
                "description": "超时时间(秒)",
                "type": "float",
                "default": 300
            },
            "proxy": {
                "description": "HTTP 代理",
                "type": "string",
                "default": ""
            }
        }
    },
    "llm_tool_settings": {
        "description": "LLM函数调用工具配置",
        "type": "object",
        "items": {
            "llm_tool_enabled": {
                "description": "启用LLM工具调用",
                "type": "bool",
                "default": false
            }
        }
    }
