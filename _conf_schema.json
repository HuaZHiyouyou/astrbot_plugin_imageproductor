{
    "prefix_config": {
        "description": "命令触发方式",
        "type": "object",
        "items": {
            "prefix_enabled": {
                "description": "启用前缀匹配",
                "type": "bool",
                "default": false
            },
            "prefix_list": {
                "description": "命令前缀列表",
                "type": "string",
                "default": "/img,/aimg"
            },
            "coexist_enabled": {
                "description": "混合模式",
                "type": "bool",
                "default": false
            }
        }
    },
    "gather_mode_config": {
        "description": "收集模式配置",
        "type": "object",
        "items": {
            "gather_mode_enabled": {
                "description": "启用收集模式",
                "type": "bool",
                "default": false
            }
        }
    },
    "whitelist_config": {
        "description": "白名单配置",
        "type": "object",
        "items": {
            "whitelist_enabled": {
                "description": "启用群组白名单",
                "type": "bool",
                "default": false
            },
            "whitelist_groups": {
                "description": "白名单群组ID",
                "type": "string",
                "default": ""
            },
            "user_enabled": {
                "description": "启用用户白名单",
                "type": "bool",
                "default": false
            },
            "user_whitelist": {
                "description": "用户ID白名单",
                "type": "string",
                "default": ""
            }
        }
    },
    "main_provider": {
        "description": "主提供商",
        "type": "object",
        "hint": "优先使用主提供商，主提供商重试机会耗尽后，依次降级回退到备用提供商重试。",
        "items": {
            "enabled": {
                "description": "启用接口",
                "type": "bool",
                "default": true
            },
            "api_name": {
                "description": "提供商名称",
                "type": "string",
                "default": "主提供商"
            },
            "api_type": {
                "description": "接口规范类型",
                "type": "string",
                "options": ["OpenAI", "Gemini", "Grok", "Zhipu", "Qianwen", "Baidu", "Hunyuan", "Seed", "Stable_Diffusion"],
                "default": "OpenAI"
            },
            "api_key": {
                "description": "API密钥",
                "type": "string",
                "default": ""
            },
            "api_url": {
                "description": "API地址",
                "type": "string",
                "default": ""
            },
            "model": {
                "description": "图像生成模型",
                "type": "string",
                "default": ""
            },
            "vision_api_key": {
                "description": "视觉模型API密钥",
                "type": "string",
                "default": ""
            },
            "vision_api_url": {
                "description": "视觉模型API地址",
                "type": "string",
                "default": ""
            },
            "vision_model": {
                "description": "视觉理解模型",
                "type": "string",
                "default": ""
            },
            "auto_switch": {
                "description": "自动切换模式",
                "type": "bool",
                "default": true,
                "hint": "带图自动切换到视觉模型"
            }
        }
    },
